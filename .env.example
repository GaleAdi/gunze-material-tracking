# PostgreSQL connection string
# Get this from Neon (https://neon.tech) or Supabase (https://supabase.com)
# Example for Neon:
#   DATABASE_URL="postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Example for Supabase:
#   DATABASE_URL="postgresql://postgres.xxx:xxxxx@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require"
DATABASE_URL="postgresql://username:password@host/dbname?sslmode=require"